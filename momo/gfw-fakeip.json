{
  "dns": {
    "servers": [
      {
        "tag": "ali-dns",
        "type": "udp",
        "server": "223.5.5.5"
      },
      {
        "tag": "google-dns",
        "type": "https",
        "server": "8.8.8.8",
        "detour": "默认代理",
        "path": "/dns-query"
      },
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
       {
        "query_type": "HTTPS",
        "action": "reject"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "action": "route",
        "server": "fakeip",
        "rewrite_ttl": 1
      },
      {
        "rule_set": [
          "meproxy",
          "foreign_domain"
        ],
        "server": "google-dns",
         "strategy": "prefer_ipv4"
      }
    ],
    "final": "ali-dns",
    "strategy": "prefer_ipv6",
    "independent_cache": true,
    "reverse_mapping": true
  },
  "route": {
    "rules": [
      {
        "inbound": "dns-in",
        "action": "hijack-dns"
      },
      {
        "rule_set": "ads",
        "outbound": "拦截"
      },
      {
        "rule_set": [
          "meproxy",
          "foreign_domain",
          "foreign_ip"
        ],
        "outbound": "默认代理"
      }
    ],
    "rule_set": [
      {
        "tag": "meproxy",
        "type": "remote",
        "format": "binary",
        "url": "https://fastly.jsdelivr.net/gh/evecus/rules_set@master/sing-box/proxy.srs",
        "download_detour": "直连",
        "update_interval": "1d"
      },
      {
        "tag": "foreign_domain",
        "type": "remote",
        "format": "binary",
        "url": "https://fastly.jsdelivr.net/gh/evecus/rules_set@master/sing-box/foreign_domain-lite.srs",
        "download_detour": "直连",
        "update_interval": "1d"
      },
      {
        "tag": "foreign_ip",
        "type": "remote",
        "format": "binary",
        "url": "https://fastly.jsdelivr.net/gh/evecus/rules_set@master/sing-box/foreign_ip4.srs",
        "download_detour": "直连",
        "update_interval": "1d"
      },
      {
        "tag": "ads",
        "type": "remote",
        "format": "binary",
        "url": "https://fastly.jsdelivr.net/gh/evecus/rules_set@master/sing-box/ads_domain-lite.srs",
        "download_detour": "直连",
        "update_interval": "1d"
      }
    ],
    "final": "直连",
    "auto_detect_interface": true,
    "default_domain_resolver": {
      "server": "ali-dns"
    }
  },
  "inbounds": [
    {
      "tag": "dns-in",
      "type": "direct",
      "listen": "::",
      "listen_port": 1153
    },
    {
      "tag": "tproxy-in",
      "type": "tproxy",
      "listen": "::",
      "listen_port": 7899,
      "sniff": false,
      "sniff_override_destination": false
    }
  ],
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "/etc/momo/run/cache.db",
      "store_fakeip": true
    },
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "external_ui": "/etc/momo/run/ui",
      "external_ui_download_url": "https://fastly.jsdelivr.net/gh/evecus/rules_set@ui/zashboard-gh-pages.zip",
      "external_ui_download_detour": "直连",
      "secret": "1234",
      "default_mode": "rule"
    }
  },
  "outbounds": [
    {
      "tag": "默认代理",
      "type": "selector",
      "outbounds": []
    },
    {
      "tag": "直连",
      "type": "direct"
    },
    {
      "tag": "拦截",
      "type": "block"
    }
  ],
  "log": {
    "disabled": true
  }
}
